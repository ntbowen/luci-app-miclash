msgstr "ТЕХНИЧЕСКИЙ"

msgid "IP-CIDR List (fake-ip whitelist mode)"
msgstr "Список IP-CIDR (режим fake-ip whitelist)"

msgid "This list is used by the firewall (nftables/iptables) to mark traffic to specified IPs and subnets for proxying in fake-ip whitelist mode. Enter one IPv4 address or CIDR per line (e.g. 8.8.8.8 or 1.2.3.0/24). Lines starting with # are treated as comments. Saving applies changes immediately without restarting Mihomo."
msgstr "Этот список используется файрволом (nftables/iptables) для маркировки трафика к указанным IP и подсетям для проксирования в режиме fake-ip whitelist. Вводите по одному IPv4-адресу или CIDR на строку (например, 8.8.8.8 или 1.2.3.0/24). Строки, начинающиеся с #, считаются комментариями. Сохранение применяет изменения немедленно без перезапуска Mihomo."

msgid "IP-CIDR whitelist saved and firewall rules updated."
msgstr "Белый список IP-CIDR сохранён, правила файрвола обновлены."

msgid "IP-CIDR whitelist saved, but firewall update failed: %s"
msgstr "Белый список IP-CIDR сохранён, но обновление файрвола не удалось: %s"

msgid "Failed to save IP-CIDR whitelist: %s"
msgstr "Не удалось сохранить белый список IP-CIDR: %s"

### Модуль settings.js ###

msgid "WAN Interfaces"
msgstr "WAN-интерфейсы"

msgid "Ethernet Interfaces"
msgstr "Ethernet-интерфейсы"

msgid "WiFi Interfaces"
msgstr "Wi-Fi интерфейсы"

msgid "USB Interfaces"
msgstr "USB-интерфейсы"

msgid "VPN Interfaces"
msgstr "VPN-интерфейсы"

msgid "Virtual Interfaces"
msgstr "Виртуальные интерфейсы"

msgid "Other Interfaces"
msgstr "Прочие интерфейсы"

msgid "Mihomo Kernel Management"
msgstr "Управление ядром Mihomo"

msgid "Download and manage the Mihomo (Clash Meta) kernel binary."
msgstr "Загрузка и управление исполняемым файлом ядра Mihomo (Clash Meta)."

msgid "Interface Processing Mode"
msgstr "Режим обработки интерфейсов"

msgid "Choose how to handle network interfaces for proxy processing."
msgstr "Выберите, как обрабатывать сетевые интерфейсы для проксирования."

msgid "Proxy Mode"
msgstr "Режим проксирования"

msgid "Choose how traffic is redirected to Clash: TPROXY (all traffic), TUN (all traffic via virtual interface), or MIXED (TCP via TPROXY, UDP via TUN — best for gaming)."
msgstr "Выберите, как перенаправлять трафик в Clash: TPROXY (весь трафик), TUN (весь трафик через виртуальный интерфейс) или MIXED (TCP через TPROXY, UDP через TUN — оптимально для игр)."

msgid "Transparent proxy mode. Routes both TCP and UDP through TPROXY port 7894. Best compatibility, requires kernel TPROXY support."
msgstr "Прозрачный режим прокси. Направляет как TCP, так и UDP через TPROXY-порт 7894. Максимальная совместимость, требуется поддержка TPROXY в ядре."

msgid "TUN interface mode. Creates virtual network interface for all traffic. Better performance, works without TPROXY. Requires TUN kernel module."
msgstr "Режим TUN-интерфейса. Создаёт виртуальный сетевой интерфейс для всего трафика. Лучшая производительность, работает без TPROXY. Требуется модуль ядра TUN."

msgid "Hybrid mode (best for gaming). TCP via TPROXY (stable), UDP via TUN (low latency). Optimal for online games requiring fast UDP."
msgstr "Гибридный режим (лучший для игр). TCP через TPROXY (стабильно), UDP через TUN (низкая задержка). Оптимален для онлайн‑игр, требующих быстрого UDP."

msgid "TUN Stack"
msgstr "Стек TUN"

msgid "Choose Mihomo TUN stack. `system` is fastest but depends on kernel capabilities; `gvisor` is more compatible; `mixed` combines both."
msgstr "Выберите стек TUN для Mihomo. `system` самый быстрый, но зависит от возможностей ядра; `gvisor` более совместим; `mixed` сочетает оба подхода."

msgid "system: kernel network stack. If TCP in TUN fails on your device, try gvisor."
msgstr "system: сетевой стек ядра. Если TCP в TUN не работает на вашем устройстве, попробуйте gvisor."

msgid "gvisor: userspace stack, usually most compatible across routers."
msgstr "gvisor: userspace-стек, обычно самый совместимый на разных роутерах."

msgid "mixed: hybrid stack mode supported by some Mihomo builds."
msgstr "mixed: гибридный режим стека, поддерживаемый некоторыми сборками Mihomo."

msgid "Automatic Interface Detection"
msgstr "Автоматическое определение интерфейсов"

msgid "Additional Settings"
msgstr "Дополнительные настройки"

msgid "Exclude Mode (Universal approach)"
msgstr "Режим исключения (универсальный)"

msgid "Process traffic from ALL interfaces except selected ones. Automatically detects and excludes WAN. Recommended for most users."
msgstr "Обрабатывать трафик со всех интерфейсов, кроме выбранных. Автоматически обнаруживает и исключает WAN. Рекомендуется для большинства пользователей."

msgid "Explicit Mode (Precise control)"
msgstr "Явный режим (точный контроль)"

msgid "Process traffic ONLY from selected interfaces. More secure but requires manual configuration. Recommended for advanced users."
msgstr "Обрабатывать трафик только с выбранных интерфейсов. Более безопасно, но требует ручной настройки. Рекомендуется для опытных пользователей."

msgid "Automatically detect LAN bridge interface"
msgstr "Автоматически определять LAN-мост"

msgid "When enabled, automatically finds the main LAN bridge. Disable to manually select specific interfaces."
msgstr "Если включено, автоматически находит основной LAN-мост. Отключите для ручного выбора интерфейсов."

msgid "Automatically detect WAN interface"
msgstr "Автоматически определять WAN-интерфейс"

msgid "When enabled, automatically detects and excludes WAN interface. Disable to manually select interfaces to exclude."
msgstr "Если включено, автоматически обнаруживает и исключает WAN-интерфейс. Отключите для ручного выбора интерфейсов для исключения."

msgid "Select interfaces to process"
msgstr "Выберите интерфейсы для обработки"

msgid "Traffic from these interfaces will be processed by the proxy."
msgstr "Трафик с этих интерфейсов будет обработан прокси."

msgid "Select interfaces to exclude"
msgstr "Выберите интерфейсы для исключения"

msgid "Traffic from these interfaces will bypass the proxy (direct routing)."
msgstr "Трафик с этих интерфейсов будет идти в обход прокси (прямая маршрутизация)."

msgid "Block QUIC traffic (UDP port 443)"
msgstr "Блокировать трафик QUIC (UDP-порт 443)"

msgid "When enabled, blocks QUIC traffic on UDP port 443. This can improve proxy effectiveness for some services like YouTube."
msgstr "Если включено, блокирует трафик QUIC по порту 443 (UDP). Это может улучшить эффективность прокси для таких сервисов, как YouTube."

